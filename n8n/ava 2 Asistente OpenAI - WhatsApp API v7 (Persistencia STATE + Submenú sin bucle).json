    {
      "parameters": {
        "jsCode": "const out = $json.output || '';\nconst match = out.match(/STATE:\\s*(\\{[\\s\\S]*\\})\\s*$/);\nlet state = null;\nlet cleanOutput = out;\nif (match) {\n  try { state = JSON.parse(match[1]); cleanOutput = out.replace(match[0], '').trim(); } catch(e) { state = null; }\n}\nreturn [{ json: { ...$json, output: cleanOutput, state, tiene_state: !!state } }];\n"
      },
