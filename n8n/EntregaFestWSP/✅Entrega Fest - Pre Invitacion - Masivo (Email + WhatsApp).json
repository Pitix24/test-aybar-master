    {
      "parameters": {
        "jsCode": "const resultados = $(\"enviar-mensaje-wsp\").all();\nconst datosOriginales = $(\"formatear-contactos\").all(); \n\n// Evolution/WhatsApp Cloud API: si tiene 'key' fue exitoso\nconst exitosos = resultados.filter(r => r.json.key && (r.json.key.remoteJid || r.json.key.id)).length;\nconst fallidos = resultados.length - exitosos;\nconst total = resultados.length;\n\nlet logDetallado = \"Resumen de envíos por WhatsApp:\\n\";\nresultados.forEach((r, index) => {\n    const status = (r.json.key) ? \"✅ OK\" : \"❌ Error\";\n    \n    // Protegemos por si datosOriginales no tiene el mismo índice\n    const nombre = datosOriginales[index]?.json?.nombres ?? \"(sin nombre)\";\n    const celular = datosOriginales[index]?.json?.celular ?? \"(sin celular)\";\n    \n    logDetallado += `${index + 1}. ${nombre} (${celular}): ${status}\\n`;\n});\n\nreturn { exitosos, fallidos, total, logDetallado, fecha: new Date().toLocaleString() };\n"
      },
